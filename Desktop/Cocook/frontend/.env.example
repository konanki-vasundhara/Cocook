# Frontend Environment Variables
# Copy this file to .env and fill in your values
# These are baked into the build at compile time by Vite

# Backend API URL
# Development: http://localhost:8000
# Production: https://your-backend-api.onrender.com (your deployed backend URL)
VITE_API_URL=

# WebSocket URL  
# Development: ws://localhost:8000
# Production: wss://your-backend-api.onrender.com (note wss:// for HTTPS)
# If left empty, auto-derives from current page URL
VITE_WS_URL=

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id
