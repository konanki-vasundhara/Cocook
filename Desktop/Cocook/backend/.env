# Database Configuration
# For local development with SQLite (default — no setup needed):
# DATABASE_URL=sqlite:///./cocook.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://postgresql:postgresql@host:5432/cocook
DATABASE_URL=sqlite:///./cocook.db

# SMTP Email Configuration (for OTP sending)
# For Gmail: generate App Password at https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=konankivasundhara@gmail.com
SMTP_PASSWORD=cyjazjwpdjgxyzsv

# Server Configuration
# Set ALLOWED_ORIGINS to your deployed frontend URL(s), comma-separated
# Leave empty for development (allows all origins)
ALLOWED_ORIGINS=
SECRET_KEY=
ENVIRONMENT=development
DEBUG=true
