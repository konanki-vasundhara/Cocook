# Database Configuration
# SQLite (default for development — no setup needed):
DATABASE_URL=sqlite:///./cocook.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@host:5432/cocook
# Render/Railway will auto-set DATABASE_URL for you

# SMTP Email Configuration (for OTP sending)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Server Configuration
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend-domain.com
SECRET_KEY=generate-a-strong-random-secret-key
ENVIRONMENT=production
DEBUG=false
